# erpnext-ai-forge .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (if any tool template adds JS)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Secrets — NEVER commit
.env
.env.*
!.env.example
secrets/
*.local.yaml
*.local.yml
*.local.md
*.key
*.pem

# Audit log — local-only per v0.2 Decision 14
audit/**/*.jsonl
audit/**/*.jsonl.gz
audit/**/*.tar.gpg
!audit/.gitkeep

# Discovery — private (key names only is public; raw values are private)
discovery/data/*.private.json

# Staging dir used by `forge sync --all`
.forge-staging/

# Temporary
*.tmp
*.bak

# Generated reports (review before committing)
forge/reports/
