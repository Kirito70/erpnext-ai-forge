# erpnext-ai-forge — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# ---------------------------------------------------------------------------
# Bench location
# ---------------------------------------------------------------------------
# Absolute path to the Frappe bench `forge sync` writes into.
FORGE_BENCH_PATH=/home/tayyab/Work/Projects/erp/novizna-v16/novizna-v16

# Primary Frappe site name. Used by tools requiring confirmation (per v0.2
# Decision 13: type this exact value to confirm destructive actions).
FORGE_PRIMARY_SITE=novizna-v16

# ---------------------------------------------------------------------------
# mariadb-query tool (v0.2 Decision 12)
# ---------------------------------------------------------------------------
# Read-only DSN for the mariadb-query tool. Recommended: a MariaDB user with
# only SELECT, SHOW, EXPLAIN, DESCRIBE grants. Do NOT reuse the site's primary
# DB user. Do NOT auto-read from sites/<site>/site_config.json.
#
# Format: mysql+pymysql://<user>:<pass>@<host>:<port>/<db>?charset=utf8mb4
FORGE_MARIADB_DSN=

# ---------------------------------------------------------------------------
# GitHub remote (for Phase 3+; not used in Phase 0)
# ---------------------------------------------------------------------------
FORGE_GITHUB_REMOTE=
FORGE_GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Audit backup
# ---------------------------------------------------------------------------
# Destination directory for monthly `forge audit backup` tar+gpg snapshots.
FORGE_AUDIT_BACKUP_DIR=

# GPG recipient (email/key ID) for audit backup encryption.
FORGE_AUDIT_GPG_RECIPIENT=
